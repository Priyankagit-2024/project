import numpy as np
import matplotlib.pyplot as plt
from ase.io import read
from ase.neighborlist import neighbor_list

# ---------------- PARAMETERS ---------------- #
poscar_file = "POSCAR"

r_max = 8.0
dr = 0.05

# ---------------- LOAD INITIAL STRUCTURE ---------------- #
atoms = read(poscar_file)

atoms.set_pbc(True)

cell = atoms.get_cell()
volume = atoms.get_volume()

symbols = atoms.get_chemical_symbols()

# ---------------- RDF FUNCTION ---------------- #
def compute_rdf_single(atoms, pair):

    bins = np.arange(0, r_max + dr, dr)
    r_centers = 0.5 * (bins[:-1] + bins[1:])
    hist = np.zeros(len(r_centers))

    symbols = atoms.get_chemical_symbols()

    rho = symbols.count(pair[1]) / volume
    N_i = symbols.count(pair[0])

    i, j, d = neighbor_list("ijd", atoms, r_max)

    for idx in range(len(d)):

        sp_i = symbols[i[idx]]
        sp_j = symbols[j[idx]]

        # include both directions
        if (sp_i, sp_j) == pair or (sp_j, sp_i) == pair:

            r = d[idx]
            bin_idx = int(r / dr)

            if bin_idx < len(hist):
                hist[bin_idx] += 1

    # normalization
    for k, r in enumerate(r_centers):

        shell_vol = 4 * np.pi * r**2 * dr
        norm = rho * shell_vol * N_i

        if norm > 0:
            hist[k] /= norm

    return r_centers, hist

# ---------------- COMPUTE RDF ---------------- #
print("Computing RDF at 0 ns...")

r_cc, g_cc = compute_rdf_single(atoms, ("Cu","Cu"))
r_co, g_co = compute_rdf_single(atoms, ("Cu","O"))
r_oo, g_oo = compute_rdf_single(atoms, ("O","O"))

# ---------------- SAVE ---------------- #
np.savetxt("rdf_Cu-Cu_0ns.dat", np.column_stack([r_cc, g_cc]))
np.savetxt("rdf_Cu-O_0ns.dat", np.column_stack([r_co, g_co]))
np.savetxt("rdf_O-O_0ns.dat", np.column_stack([r_oo, g_oo]))

# ---------------- PLOT ---------------- #
plt.figure(figsize=(6,5))

plt.plot(r_cc, g_cc, label="Cu-Cu (0 ns)")
plt.plot(r_co, g_co, label="Cu-O (0 ns)")
plt.plot(r_oo, g_oo, label="O-O (0 ns)")

plt.xlabel("r (Å)", fontsize=14, fontweight='bold')
plt.ylabel("g(r)", fontsize=14, fontweight='bold')

plt.xticks(fontsize=12, fontweight='bold')
plt.yticks(fontsize=12, fontweight='bold')

plt.legend()
plt.grid(alpha=0.3)

plt.savefig("rdf_0ns.png", dpi=300)
plt.show()

# ---------------- FIND PEAKS ---------------- #
def find_peaks(r, g):

    peaks = []

    for i in range(1, len(g)-1):
        if g[i] > g[i-1] and g[i] > g[i+1]:
            peaks.append((r[i], g[i]))

    peaks = sorted(peaks, key=lambda x: x[1], reverse=True)

    return peaks[:3]

# ---------------- WRITE PEAKS ---------------- #
with open("rdf_peaks_0ns.txt", "w") as f:

    for label, (r_vals, g_vals) in {
        "Cu-Cu": (r_cc, g_cc),
        "Cu-O": (r_co, g_co),
        "O-O": (r_oo, g_oo),
    }.items():

        peaks = find_peaks(r_vals, g_vals)

        f.write(f"{label} peaks (0 ns):\n")
        for r_p, g_p in peaks:
            f.write(f"  r = {r_p:.3f} Å, g(r) = {g_p:.4f}\n")
        f.write("\n")

print("✅ RDF at 0 ns computed + peaks saved")
